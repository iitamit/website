# Development defaults to SQLite when POSTGRES_DB is not set.
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,dash.localhost
DJANGO_SECRET_KEY=replace-this-in-production

# Set these values to use the dedicated PostgreSQL database.
POSTGRES_DB=ik_seoul_db
POSTGRES_USER=ik_seoul_user
POSTGRES_PASSWORD=replace-with-a-strong-password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
